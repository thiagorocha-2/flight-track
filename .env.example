# --- Tracker local / GitHub Actions (scraping + post no Slack) ---
# Escopos do bot: chat:write (e im:write se for usar DM)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Canal ou grupo (C.../G...). Se vazio, usa DM com SLACK_USER_ID
# SLACK_CHANNEL_ID=C01234567890

# Opcional: thread (com SLACK_CHANNEL_ID)
# SLACK_THREAD_TS=1234567890.123456

# Se não usar canal: DM para este usuário
# SLACK_USER_ID=U01234567890

# --- Servidor Slack (slash command /flight-track) — so se hospedar o server/ ---
# Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=

# Fine-grained PAT: Contents R/W + Actions (se disparar workflow) no repo flight-track
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=seu-usuario/flight-track
# GITHUB_BRANCH=main

# Opcional: apos adicionar voo, dispara o workflow do Actions
# TRIGGER_WORKFLOW_AFTER_ADD=true

# Opcional: restrinja quem pode usar o slash command (IDs separados por virgula)
# SLACK_ALLOW_USER_IDS=U0123,U0456

# Opcional: sobrescreve User-Agent do Playwright (debug em CI)
# PLAYWRIGHT_USER_AGENT=Mozilla/5.0 ...
